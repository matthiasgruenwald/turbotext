{
  "permissions": {
    "allow": [
      "Read(//Users/mg/.claude/skills/**)",
      "Read(//Users/mg/.claude/**)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git reset *)",
      "Bash(git ls-tree *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git merge *)",
      "Bash(git ls-remote *)",
      "Bash(git -C * remote get-url *)",
      "Bash(git -C * *)",
      "Bash(gh auth *)",
      "Bash(gh issue *)",
      "Bash(gh label *)",
      "Bash(gh api *)",
      "Bash(gh repo *)",
      "Bash(gh pr *)",
      "Bash(grep *)",
      "Bash(xargs *)",
      "Bash(find . *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(curl -s --max-time 5 *)",
      "Bash(mktemp *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-swift-file-length.sh",
            "timeout": 5
          }
        ],
        "description": "Warn when an edited Swift file exceeds the 800-line limit from CLAUDE.md",
        "id": "post:swift-file-length-check"
      }
    ]
  }
}
